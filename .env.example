# ── Required ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GCP_PROJECT_ID=your-gcp-project

# ── BigQuery ────────────────────────────────────────────────────────
BQ_DATASET=bi_copilot
BQ_LOCATION=EU
BQ_MAX_BYTES_BILLED=10737418240
BQ_QUERY_TIMEOUT_SECONDS=30

# ── LLM ─────────────────────────────────────────────────────────────
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=60

# ── Agent loop ──────────────────────────────────────────────────────
SQL_MAX_ITERATIONS=5
SQL_DRY_RUN_REQUIRED=true
PLANNER_MAX_TABLES=8

# ── App ─────────────────────────────────────────────────────────────
ENV=dev
LOG_LEVEL=INFO

# ── API ─────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RATE_LIMIT_PER_MINUTE=30

# ── Observability (optional — runs without these) ───────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
